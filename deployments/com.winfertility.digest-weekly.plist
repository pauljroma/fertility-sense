<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>com.winfertility.digest-weekly</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/expo/fertility-sense/.venv/bin/python</string>
        <string>-m</string>
        <string>fertility_sense</string>
        <string>digest</string>
        <string>--weekly</string>
        <string>--to</string>
        <string>paul@romatech.com</string>
    </array>
    <key>WorkingDirectory</key><string>/Users/expo/fertility-sense</string>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key><integer>1</integer>
        <key>Hour</key><integer>8</integer>
        <key>Minute</key><integer>0</integer>
    </dict>
    <key>StandardOutPath</key><string>/Users/expo/fertility-sense/data/logs/digest-weekly.log</string>
    <key>StandardErrorPath</key><string>/Users/expo/fertility-sense/data/logs/digest-weekly.err</string>
</dict>
</plist>
