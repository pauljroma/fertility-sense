# WIN Fertility Environment Variables
# Copy to .env and fill in values.

# --- Required ---
FERTILITY_SENSE_API_KEY=your-api-key-here
FERTILITY_SENSE_ANTHROPIC_API_KEY=sk-ant-...

# --- Server ---
# FERTILITY_SENSE_HOST=127.0.0.1
# FERTILITY_SENSE_PORT=9300

# --- CORS ---
# Comma-separated list of allowed origins (JSON array format)
# FERTILITY_SENSE_CORS_ORIGINS=["http://localhost:3000"]

# --- Reddit Feed (optional, legacy — consumer demand sensing) ---
# FERTILITY_SENSE_REDDIT_CLIENT_ID=
# FERTILITY_SENSE_REDDIT_CLIENT_SECRET=
# FERTILITY_SENSE_REDDIT_USER_AGENT=fertility-sense/0.1.0

# --- Cost Controls ---
# FERTILITY_SENSE_COST_BUDGET_USD=10.0
# FERTILITY_SENSE_RATE_LIMIT_RPM=60

# --- Scoring Weights ---
# FERTILITY_SENSE_W_DEMAND=0.30
# FERTILITY_SENSE_W_CLINICAL=0.25
# FERTILITY_SENSE_W_TRUST=0.25
# FERTILITY_SENSE_W_COMMERCIAL=0.20

# --- Safety Gates ---
# FERTILITY_SENSE_TRUST_BLOCK_THRESHOLD=20.0
# FERTILITY_SENSE_CLINICAL_ESCALATION_THRESHOLD=80.0
# FERTILITY_SENSE_TRUST_ESCALATION_THRESHOLD=40.0

# --- Email (IONOS SMTP/IMAP) ---
FERTILITY_SENSE_EMAIL_ADDRESS=fertility@exponentialcap.com
FERTILITY_SENSE_EMAIL_PASSWORD=
FERTILITY_SENSE_SMTP_HOST=smtp.ionos.com
FERTILITY_SENSE_SMTP_PORT=587
FERTILITY_SENSE_IMAP_HOST=imap.ionos.com
FERTILITY_SENSE_IMAP_PORT=993
FERTILITY_SENSE_EMAIL_FROM_NAME=WIN Fertility

# --- WIN Fertility Branding ---
# FERTILITY_SENSE_COMPANY_NAME=WIN Fertility
# FERTILITY_SENSE_COMPANY_TAGLINE=Best treatment at lowest cost — managed fertility benefits for employers
# FERTILITY_SENSE_COMPANY_WEBSITE=https://winfertility.com
# FERTILITY_SENSE_SALES_EMAIL=sales@winfertility.com
# FERTILITY_SENSE_SUPPORT_EMAIL=support@winfertility.com

# --- Alert email (receives digests and scout alerts) ---
FERTILITY_SENSE_ALERT_EMAIL=paul@romatech.com
